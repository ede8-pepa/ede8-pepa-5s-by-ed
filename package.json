{
  "name": "5s-by-ed",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "ulimit -n 65536 && WATCHPACK_POLLING=true NEXT_TELEMETRY_DISABLED=1 NEXT_DIST_DIR=.next-3010 next dev -H 127.0.0.1 -p 3010",
    "dev:webpack": "ulimit -n 65536 && WATCHPACK_POLLING=true NEXT_TELEMETRY_DISABLED=1 NEXT_DIST_DIR=.next-3010 next dev -H 127.0.0.1 -p 3010",
    "dev:turbo": "ulimit -n 65536 && NEXT_TELEMETRY_DISABLED=1 NEXT_DIST_DIR=.next-3010-turbo next dev --turbopack -H 127.0.0.1 -p 3010",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "appwrite": "^26.0.0",
    "next": "^15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3"
  }
}
